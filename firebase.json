{
  "hosting": {
    "public": "build",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [{ "source": "**", "destination": "/index.html" }],
    "headers": [
      { "source": "**/*.@(js|css)", "headers": [{ "key": "Cache-Control", "value": "public, max-age=300, must-revalidate" }] },
      { "source": "**/*.@(png|jpg|jpeg|gif|svg|ico|webp)", "headers": [{ "key": "Cache-Control", "value": "public, max-age=300, must-revalidate" }] },
      { "source": "**/*.html", "headers": [{ "key": "Cache-Control", "value": "no-cache" }] }
    ]
  }
}
